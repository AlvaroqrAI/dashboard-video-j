# ---- Frontend (Vite) ----
# Copia este archivo a .env y rellena los valores.
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ---- Backend (Edge Functions / secrets de Supabase) ----
# Estos NO van en el .env del frontend. Se configuran con:
#   supabase secrets set NOMBRE=valor
#
# SUPABASE_URL=...                 (lo inyecta Supabase automáticamente)
# SUPABASE_ANON_KEY=...            (lo inyecta Supabase automáticamente)
# SUPABASE_SERVICE_ROLE_KEY=...    (lo inyecta Supabase automáticamente)
# APP_ENCRYPTION_KEY=...           (openssl rand -base64 32)
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# APP_URL=http://localhost:5173
